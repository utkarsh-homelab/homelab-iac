# Terraform auto-loads all *.auto.tfvars files, so
# this file is picked up automatically alongside
# terraform.tfvars.
#
# DO NOT commit secrets.auto.tfvars to Git.
# It is listed in .gitignore.
# ──────────────────────────────────────────────

proxmox_api_token = "root@pam!my-token=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
